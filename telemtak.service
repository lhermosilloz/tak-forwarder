[Unit]
Description=PX4 to TAK Server Telemetry Bridge
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/usr/bin/python3 /opt/telemtak/telemTAK.py
Restart=always
RestartSec=5
User=root
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target